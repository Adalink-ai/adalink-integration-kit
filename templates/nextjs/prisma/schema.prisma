// Schema inicial do app integrado. Troque/estenda conforme o seu domínio.
// O chat com o Adaflow NÃO depende de banco — este modelo é um exemplo de
// persistência local (histórico de conversas do usuário no seu app).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ChatSession {
  id        String   @id @default(uuid()) @db.Uuid
  /// Id do usuário no Adaflow (claim `sub` do JWT do SSO)
  userId    String
  /// `chatId` retornado pela plataforma (header x-chat-id) para retomar a conversa
  chatId    String   @unique
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
