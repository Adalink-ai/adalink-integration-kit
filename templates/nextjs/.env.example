# URL do Postgres do SEU app (o chat com o Adaflow não depende de banco)
DATABASE_URL="postgresql://user:password@localhost:5432/meu_app"

# Base URL do gateway da plataforma (default: produção)
# ADAFLOW_BASE_URL="https://adalink-api-gateway.onrender.com"

# Modelo do catálogo usado no chat genérico (GET /v1/openai/models lista todos)
# ADAFLOW_MODEL="anthropic/claude-haiku-4.5"

# URL do Adaflow para o SSO handoff (app precisa estar em domínio adalink.ai/.app)
NEXT_PUBLIC_ADAFLOW_URL="https://app.adalink.ai"
